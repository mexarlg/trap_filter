#==============================================================================
# trap_pulse_shaper.ldc  -  Timing constraints (pre-synthesis)
# Device : LFCPNX-100-9LFG672C  (CertusPro-NX Evaluation Board)
#==============================================================================

#------------------------------------------------------------------------------
# Clock  (125 MHz)
#------------------------------------------------------------------------------
create_clock -name {clk_125} -period 8.0 [get_ports CLK_I]

#------------------------------------------------------------------------------
# Reset  (assigned to a button)
#------------------------------------------------------------------------------
set_false_path -from [get_ports RST_N_I]